    "check": "pnpm generate && pnpm typecheck && pnpm lint && pnpm validate:registry",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "^1.23.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "shadcn": "4.12.0",
    "shiki": "4.3.1",
    "tailwindcss": "^4.3.2",
