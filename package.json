{
  "name": "kinetiq",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "prebuild": "pnpm generate",
    "build": "next build",
    "start": "next start",
    "generate": "tsx scripts/build-registry.ts && tsx scripts/extract-sources.ts && tsx scripts/build-search-index.ts",
    "validate:registry": "tsx scripts/validate-registry.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
